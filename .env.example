# Copy this to `.env` and fill in real values for local development.
# .env is gitignored.

# OpenAI — required for daily/trend analysis (existing)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Google Sheets backend
SHEET_ID=                              # spreadsheet ID from the sheet URL
WORKSHEET_NAME=Sheet1
GOOGLE_APPLICATION_CREDENTIALS=         # absolute path to service account JSON

# Slack incoming webhook (optional locally; required for batch_reminder.py --slack)
SLACK_WEBHOOK_URL=

# Streamlit app URL surfaced as button in Slack reminder
APP_URL=https://ligibiometrics.streamlit.app/
