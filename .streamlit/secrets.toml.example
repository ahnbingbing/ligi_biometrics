# Copy this to `.streamlit/secrets.toml` for local Streamlit dev,
# or paste the same content into Streamlit Cloud → Settings → Secrets.
# secrets.toml is gitignored.

sheet_id = "REPLACE_WITH_SHEET_ID"
worksheet_name = "Sheet1"
slack_webhook_url = "https://hooks.slack.com/services/REPLACE/REPLACE/REPLACE"

# Existing OpenAI config — keep if you use the in-app analysis
openai_api_key = "sk-REPLACE"
openai_model = "gpt-4.1-mini"

# Paste the contents of your service_account.json here, field by field.
[gcp_service_account]
type = "service_account"
project_id = "REPLACE"
private_key_id = "REPLACE"
private_key = "-----BEGIN PRIVATE KEY-----\nREPLACE\n-----END PRIVATE KEY-----\n"
client_email = "REPLACE@REPLACE.iam.gserviceaccount.com"
client_id = "REPLACE"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "REPLACE"
universe_domain = "googleapis.com"
